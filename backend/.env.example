# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
ENABLE_SWAGGER=true

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
# Required for Prisma migrations with Neon or other pooled providers.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# JWT Configuration
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_REFRESH_EXPIRES_IN=7d

# External APIs
OPENWEATHER_API_KEY=your-openweathermap-api-key
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# FAO Open Data
FAO_API_BASE_URL=https://www.fao.org/faostat/api/v1
FAO_DOMAIN_CODE=QCL

# Copernicus/Sentinel Hub (requires registration)
COPERNICUS_CLIENT_ID=your-sentinel-hub-client-id
COPERNICUS_CLIENT_SECRET=your-sentinel-hub-client-secret
COPERNICUS_BASE_URL=https://services.sentinel-hub.com

# Cron Jobs
WEATHER_UPDATE_CRON=0 */6 * * *
IOT_ANOMALY_CHECK_CRON=*/5 * * * *

# Cache
CACHE_TTL=3600
CACHE_MAX_ITEMS=1000

# Rate Limiting
API_RATE_LIMIT_TTL=60
API_RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:4200

# WebSocket
WS_PORT=3001

# Notification
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
NOTIFICATION_FROM=noreply@agricane.com
